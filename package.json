{
  "name": "db-operator",
  "version": "1.0.3",
  "description": "Cross-platform database management client for MySQL and PostgreSQL",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "node scripts/run-dev.mjs",
    "dev:web": "vite --config vite.web.config.ts",
    "check:env": "node scripts/check-env.mjs",
    "setup:linux": "bash scripts/setup-linux-deps.sh",
    "setup:linux:user": "node scripts/setup-linux-deps-user.mjs",
    "setup:wslg": "npm run setup:linux",
    "platform": "node scripts/print-platform.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "verify:macos": "node scripts/verify-macos-artifact.mjs",
    "build": "npm run typecheck && NODE_OPTIONS=--max-old-space-size=8192 electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:win:zip": "npm run build && electron-builder --win zip",
    "build:win:dir": "npm run build && electron-builder --win --dir",
    "build:mac": "NODE_OPTIONS=--max-old-space-size=8192 electron-vite build && electron-builder --mac",
    "build:linux": "NODE_OPTIONS=--max-old-space-size=8192 electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@monaco-editor/react": "^4.7.0",
    "antd": "^6.4.4",
    "electron-store": "^11.0.2",
    "monaco-editor": "^0.55.1",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sharp": "^0.35.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
